{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HealthHive",
  "version": "0.1.0",
  "identifier": "com.healthhive.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "HealthHive",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Matthew Woods",
    "homepage": "https://github.com/Mwoods30/HealthHive",
    "category": "Medical",
    "shortDescription": "HealthHive packages the patient, provider, and admin experience as a native app.",
    "longDescription": "HealthHive brings together patient timelines, appointments, billing, provider review queues, and admin operations in a single native desktop and mobile client powered by the existing React application.",
    "copyright": "Copyright (c) 2026 Matthew Woods",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleVersion": "0.1.0",
      "minimumSystemVersion": "12.0",
      "dmg": {
        "windowSize": {
          "width": 720,
          "height": 440
        },
        "appPosition": {
          "x": 200,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 510,
          "y": 190
        }
      }
    },
    "iOS": {
      "bundleVersion": "0.1.0",
      "minimumSystemVersion": "14.0"
    },
    "android": {
      "minSdkVersion": 24,
      "versionCode": 100
    }
  }
}
